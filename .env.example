# ============================================================
# Kilat Shop — environment config
# Copy to `.env` and fill in. The app runs fully with just the
# first two set; everything else is optional and degrades safely.
# ============================================================

# Database (SQLite for local dev — switch to Postgres for production)
DATABASE_URL="file:./dev.db"

# Auth — generate a long random string (e.g. `openssl rand -base64 48`)
AUTH_SECRET="change-me"

# Public site
NEXT_PUBLIC_STORE_NAME="Kilat Shop"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------- Login with Google (optional) ----------
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <APP_BASE_URL>/api/auth/google/callback
# Leave empty to hide the "Login with Google" button (app still works).
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ---------- Payment ----------
# Provider: "simulation" (default, instant success) | "midtrans" | "tripay"
# If a real provider is selected but its keys are missing, it falls back to simulation.
PAYMENT_PROVIDER="simulation"
APP_BASE_URL="http://localhost:3000"   # used to build webhook/return URLs

# Midtrans (Snap). Webhook URL: <APP_BASE_URL>/api/webhook/midtrans
# MIDTRANS_SERVER_KEY=""
# MIDTRANS_CLIENT_KEY=""
# MIDTRANS_IS_PRODUCTION="false"

# Tripay (QRIS / VA / e-wallet). Webhook URL: <APP_BASE_URL>/api/webhook/tripay
# TRIPAY_API_KEY=""
# TRIPAY_PRIVATE_KEY=""
# TRIPAY_MERCHANT_CODE=""
# TRIPAY_IS_PRODUCTION="false"
# TRIPAY_PAYMENT_METHOD="QRIS"

# ---------- Wallet / Top up ----------
# TOPUP_MIN="10000"
# TOPUP_MAX="5000000"
# TOPUP_PRESETS="20000,50000,100000,250000"
# WITHDRAW_MIN="10000"             # minimum balance withdrawal

# ---------- Orders ----------
# ORDER_EXPIRY_MINUTES="60"        # unpaid orders auto-cancel after this many minutes
# CRON_SECRET=""                   # protects GET /api/cron/expire-orders (optional)

# ---------- Membership (premium / reseller) ----------
# PREMIUM_FEE="50000"              # upfront fee to become reseller (paid from balance)
# PREMIUM_DAYS="30"                # membership duration per purchase
# RESELLER_DISCOUNT_PERCENT="10"   # reseller discount % applied at checkout

# ---------- Notifications (email + WhatsApp) ----------
# All optional. With none set, notifications are only LOGGED (app still works).
# NOTIFY_ENABLED="true"
# NOTIFY_LOG_BODY="redacted"        # default "redacted" masks credentials at rest; set "full" to store them
# NOTIFY_ON_ORDER_CREATED="false"

# Email — Resend (recommended) or SMTP
# NOTIFY_EMAIL_PROVIDER="resend"   # "resend" | "smtp" (auto-detected if unset)
# RESEND_API_KEY=""
# RESEND_FROM="Kilat Shop <no-reply@yourdomain.com>"
# SMTP_HOST=""                     # SMTP fallback (needs `npm i nodemailer`)
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE="false"

# WhatsApp — Fonnte
# NOTIFY_WA_PROVIDER="fonnte"
# FONNTE_TOKEN=""
# FONNTE_COUNTRY_CODE="62"
