# ============================================================
#  Kilat — production environment (VPS)
#  Copy this to ".env" ON YOUR VPS and fill the real values.
#  NEVER commit the real .env (it's gitignored).
# ============================================================

# --- Database: SQLite file on the VPS disk ---
# Absolute path is safest so PM2/cron resolve it the same way regardless of cwd.
# Adjust /var/www/kilat to wherever you put the project.
DATABASE_URL="file:/var/www/kilat/prisma/prod.db"

# --- Auth secret (REQUIRED — sessions break/insecure without it) ---
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="PASTE_A_LONG_RANDOM_STRING_HERE"

# --- Public site URLs (REQUIRED) ---
NEXT_PUBLIC_SITE_URL="https://kilat.shop"
APP_BASE_URL="https://kilat.shop"
NEXT_PUBLIC_STORE_NAME="Kilat"

# --- Order-expiry cron auth (recommended; generate like AUTH_SECRET) ---
CRON_SECRET="PASTE_ANOTHER_RANDOM_STRING_HERE"

# --- Payments: keep "simulation" until you add real gateway keys ---
PAYMENT_PROVIDER="simulation"

# --- Wallet / top up (defaults; change if you want) ---
TOPUP_MIN="10000"
TOPUP_MAX="5000000"
TOPUP_PRESETS="20000,50000,100000,250000"

# --- Notifications: leave provider keys empty to only LOG (app still works) ---
NOTIFY_ENABLED="true"
NOTIFY_LOG_BODY="redacted"

# ============================================================
#  OPTIONAL — fill only when you're ready to enable each one.
# ============================================================
# Login with Google (redirect URI: https://kilat.shop/api/auth/google/callback)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
#
# Email via Resend (or use SMTP_* — see .env.example):
# RESEND_API_KEY=""
# EMAIL_FROM="Kilat <noreply@kilat.shop>"
#
# WhatsApp via Fonnte:
# FONNTE_TOKEN=""
#
# Payment gateways (see .env.example for the full list):
# MIDTRANS_SERVER_KEY=""
# TRIPAY_API_KEY=""
